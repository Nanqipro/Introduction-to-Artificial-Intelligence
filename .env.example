# Copy to .env and fill every blank secret before starting the backend.
MYSQL_ROOT_PASSWORD=
DB_NAME=AI_platform
DB_USERNAME=ai_platform
DB_PASSWORD=
DB_PORT=3307
JWT_SECRET=

# Optional mail-based password reset and verification.
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Local development defaults.
FRONTEND_URL=http://localhost:5173
UPLOAD_BASE_URL=http://localhost:8082/
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
